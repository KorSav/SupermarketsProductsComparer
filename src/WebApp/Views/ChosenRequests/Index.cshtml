@using ApplicationCore.Entities.Product
@using ApplicationCore.Entities.Request
@using ApplicationCore.Utils
@model Dictionary<StoredRequest, PaginatedList<Product>>
@{
    ViewData["Title"] = "Обране";
}

<div class="container">

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center my-5" role="alert">
            <i class="bi bi-info-circle"></i> У вас немає збережених запитів.
            Натисніть <i class="bi bi-star"></i> поруч із кнопкою пошуку, щоб зберегти запит.
        </div>
    }
    else
    {
        @foreach (var (stored, products) in Model)
        {
            <div class="border rounded my-4">
                <div class="d-flex justify-content-between align-items-center p-3 bg-light">
                    <div>
                        <h4 class="text-primary mb-1">@stored.Request.SearchString</h4>
                        @if (stored.Request.SortBy is SortBy.Price or SortBy.UnifiedPrice)
                        {
                            <p class="mb-0 text-muted">
                                @if (stored.Request.SortOrder is SortOrder.Asc)
                                {
                                    <text>Найдешевші</text>
                                }
                                else
                                {
                                    <text>Найдорожчі</text>
                                }
                                товари
                                @if (stored.Request.SortBy is SortBy.UnifiedPrice)
                                {
                                    <text>за загальною ціною</text>
                                }
                            </p>
                        }
                    </div>
                    <div>
                        <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse"
                                data-bs-target="#group-@stored.Id" aria-expanded="true"
                                aria-controls="group-@stored.Id">
                            <i class="bi bi-chevron-down"></i> Згорнути/Розгорнути
                        </button>
                        <a asp-controller="Home" asp-action="Index" asp-route-find="@stored.Request.SearchString"
                               asp-route-sortBy="@stored.Request.SortBy" asp-route-sortOrder="@stored.Request.SortOrder"
                               class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-three-dots"></i> Більше
                        </a>
                    </div>
                </div>

                <div class="collapse" id="group-@stored.Id">
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 p-3">
                        @foreach (var product in products)
                        {
                            <div class="col">
                                <div class="card h-100 position-relative">
                                    <img src="@product.LinkImage" class="card-img-top"
                                         style="max-height: 10rem; object-fit: contain;" alt="@product.Name">
                                    <span class="badge bg-secondary position-absolute top-0 end-0 m-2">
                                        @product.Shop
                                    </span>
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="badge bg-primary fs-6 px-2 py-1">
                                                @product.Price грн
                                            </span>
                                        </div>
                                        <h6 class="card-title text-center mb-2">
                                            @product.Name
                                        </h6>
                                        <div class="mt-auto text-center">
                                            <a href="@product.LinkProduct" target="_blank"
                                                   class="btn btn-outline-secondary w-100 btn-sm">
                                                На сайт магазину
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

    }
</div>
